{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:daily",
    "group:apollo-serverMonorepo",
    "group:apolloclientMonorepo",
    "group:awsappsyncMonorepo",
    "group:aws-sdk-js-v3Monorepo",
    "group:definitelyTyped",
    "group:emotionMonorepo",
    "group:graphqlcodegeneratorMonorepo",
    "group:jestMonorepo",
    "group:jestPlusTSJest",
    "group:jestPlusTypes",
    "group:material-uiMonorepo",
    "group:storybookMonorepo",
    "group:nextjsMonorepo",
    "group:prismaMonorepo",
    "group:typescript-eslintMonorepo",
    "group:vite"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "postUpdateOptions": ["yarnDedupeHighest"],
  "prConcurrentLimit": 10,
  "updateInternalDeps": true,
  "toolSettings": {
    "nodeMaxMemory": 2048
  },
  "recreateWhen": "never",
  "assignees": ["Borales"],
  "reviewers": ["Borales"],
  "nvm": { "enabled": false },
  "packageRules": [
    {
      "groupName": "kubb-packages",
      "matchPackagePatterns": "^@kubb/.*"
    },
    {
      "groupName": "nestjs-packages",
      "matchPackagePatterns": [
        "^reflect-metadata$",
        "^rxjs$",
        "^nestjs.*",
        "^@nestjs/.*"
      ],
      "prPriority": 10
    },
    {
      "groupName": "react-packages",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ]
    },
    {
      "groupName": "aws-amplify-js",
      "matchSourceUrls": ["https://github.com/aws-amplify/amplify-js{/,}**"]
    },
    {
      "groupName": "eslint-plugins",
      "matchPackagePatterns": ["^eslint-plugin-.*"]
    },
    {
      "groupName": "zitadel-docker",
      "matchSourceUrls": ["https://github.com/zitadel/zitadel{/,}**"]
    },
    {
      "groupName": "github-actions",
      "matchSourceUrls": ["https://github.com/actions{/,}**"]
    },
    {
      "groupName": "graphql-yoga-packages",
      "matchPackagePatterns": ["graphql-yoga"]
    },
    {
      "groupName": "ai-packages",
      "matchSourceUrls": ["https://github.com/vercel/ai{/,}**"]
    },
    {
      "groupName": "hero-ui-packages",
      "matchSourceUrls": ["https://github.com/heroui-inc/heroui{/,}**"]
    }
  ]
}
